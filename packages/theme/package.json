{
  "name": "@glassbox/theme",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind": {
      "types": "./dist/tailwind.d.ts",
      "default": "./dist/tailwind.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup src/index.ts src/tailwind.ts --format esm --dts --clean=false --watch",
    "build": "tsup src/index.ts src/tailwind.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(no lint yet)\""
  },
  "devDependencies": {
    "tailwindcss": "^4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}

