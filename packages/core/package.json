{
  "name": "@glassbox/core",
  "version": "0.1.0",
  "description": "Pure TypeScript DAG state machine for AI thought trees \u2014 the core of the Glassbox XAI framework.",
  "keywords": [
    "ai",
    "xai",
    "explainability",
    "transparency",
    "dag",
    "thought-tree",
    "ux"
  ],
  "homepage": "https://github.com/samkaestner/glass-box",
  "repository": {
    "type": "git",
    "url": "https://github.com/samkaestner/glass-box.git",
    "directory": "packages/core"
  },
  "license": "MIT",
  "author": "Sam Kaestner",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format esm --dts --clean=false --watch",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}