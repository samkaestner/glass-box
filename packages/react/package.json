{
  "name": "@glassbox/react",
  "version": "0.1.0",
  "description": "React UI components for AI transparency \u2014 SpatialRail, Execution Gate, Conflict Resolution, and Confidence Provenance.",
  "keywords": [
    "ai",
    "xai",
    "explainability",
    "react",
    "spatial-rail",
    "thought-tree",
    "ux",
    "trust"
  ],
  "homepage": "https://github.com/samkaestner/glass-box",
  "repository": {
    "type": "git",
    "url": "https://github.com/samkaestner/glass-box.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Sam Kaestner",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.tsx --format esm --dts --clean=false --watch --external react react-dom",
    "build": "tsup src/index.tsx --format esm --dts --clean --external react react-dom",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@glassbox/core": "workspace:*",
    "@glassbox/theme": "workspace:*",
    "framer-motion": "^12.23.12"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.7",
    "@types/react-dom": "^19.1.5",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}